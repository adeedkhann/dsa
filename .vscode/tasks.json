{
    "version": "2.0.0",
    "tasks": [
        {
            "type": "shell",
            "label": "Compile and Run CP",
            "command": "cmd",
            "args": [
                "/c",
                "C:\\msys64\\ucrt64\\bin\\g++.exe -std=c++17 -o ${fileBasenameNoExtension}.exe ${file} && ${fileBasenameNoExtension}.exe < input.txt > output.txt"
            ],
            "options": {
                "cwd": "${fileDirname}"
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "echo": true,
                "reveal": "silent",
                "focus": false,
                "panel": "shared",
                "showReuseMessage": false,
                "clear": true
            },
            "problemMatcher": ["$gcc"]
        }
    ]
}